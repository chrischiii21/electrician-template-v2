---
// ElectriTrade Footer Component
---

<footer class="w-full bg-primary text-background">
    <!-- Main Footer Content -->
    <div class="max-w-[1920px] mx-auto px-4 md:px-12 py-12 md:py-16">
        <!-- Logo and Tagline -->
        <div class="text-center mb-6 md:mb-8">
            <div class="flex items-center justify-center mb-3 md:mb-4">
                <img
                    src="/logo.png"
                    alt="ElectriTrade Logo"
                    class="h-12 md:h-16 w-auto object-contain"
                />
            </div>

            <!-- Star Rating -->
            <div class="flex items-center justify-center gap-1 mb-2">
                <svg
                    class="w-3 md:w-4 h-3 md:h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"
                    ></path>
                </svg>
                <svg
                    class="w-3 md:w-4 h-3 md:h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"
                    ></path>
                </svg>
                <svg
                    class="w-3 md:w-4 h-3 md:h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"
                    ></path>
                </svg>
                <svg
                    class="w-3 md:w-4 h-3 md:h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"
                    ></path>
                </svg>
                <svg
                    class="w-3 md:w-4 h-3 md:h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"
                    ></path>
                </svg>
            </div>

            <h4
                class="text-base md:text-lg font-heading font-bold text-background mb-1 md:mb-2"
            >
                Trusted by 1000+ People Like You
            </h4>
            <p class="text-sm md:text-base text-background/80">
                Contact us Today to Get Free Estimate
            </p>
        </div>

        <!-- Navigation Links -->
        <nav
            class="flex flex-wrap items-center justify-center gap-3 md:gap-8 mb-8 md:mb-12"
        >
            <a
                href="/"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                HOME
            </a>
            <a
                href="/about"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                ABOUT US
            </a>
            <a
                href="/services"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                SERVICE AREA
            </a>
            <a
                href="/contact"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                CONTACT US
            </a>
            <a
                href="/specials"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                SPECIALS / COUPONS
            </a>
            <a
                href="/financing"
                class="text-xs md:text-sm text-background hover:text-accent transition-colors uppercase tracking-wide font-semibold"
            >
                FINANCING
            </a>
        </nav>

        <!-- CTA Buttons -->
        <div
            class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-8 md:mb-12"
        >
            <!-- Request Quote -->
            <a
                href="/quote"
                class="bg-accent hover:bg-accent/90 text-background px-4 md:px-6 py-3 md:py-4 flex items-center gap-2 md:gap-3 transition-colors justify-start text-sm md:text-base"
            >
                <svg
                    class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
                    ></path>
                    <path
                        d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
                    ></path>
                </svg>
                <div class="text-left">
                    <div class="text-xs uppercase tracking-wider opacity-90">
                        Simple & Free
                    </div>
                    <div class="font-bold text-xs md:text-sm">
                        Request a Quote
                    </div>
                </div>
            </a>

            <!-- Call Us -->
            <a
                href="tel:+1234567890"
                class="bg-accent hover:bg-accent/90 text-background px-4 md:px-6 py-3 md:py-4 flex items-center gap-2 md:gap-3 transition-colors justify-start text-sm md:text-base"
            >
                <svg
                    class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                </svg>
                <div class="text-left">
                    <div class="text-xs uppercase tracking-wider opacity-90">
                        Call us
                    </div>
                    <div class="font-bold text-xs md:text-sm">
                        (123) 456-7890
                    </div>
                </div>
            </a>

            <!-- Email Us -->
            <a
                href="mailto:info@electritrade.com"
                class="bg-accent hover:bg-accent/90 text-background px-4 md:px-6 py-3 md:py-4 flex items-center gap-2 md:gap-3 transition-colors justify-start text-sm md:text-base"
            >
                <svg
                    class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                </svg>
                <div class="text-left">
                    <div class="text-xs uppercase tracking-wider opacity-90">
                        Email us
                    </div>
                    <div class="font-bold text-xs md:text-sm">
                        info@electritrade.com
                    </div>
                </div>
            </a>
        </div>

        <!-- Address and Service Areas -->
        <div
            class="flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4 pt-6 md:pt-8 border-t border-background/20"
        >
            <!-- Address -->
            <div class="flex items-center gap-2">
                <svg
                    class="w-4 h-4 text-accent shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        fill-rule="evenodd"
                        d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                        clip-rule="evenodd"></path>
                </svg>
                <span class="text-xs md:text-sm text-background font-semibold"
                    >Address: Los Angeles, CA</span
                >
            </div>

            <!-- Service Areas -->
            <div
                class="flex flex-col md:flex-row items-start md:items-center gap-2 w-full md:w-auto"
            >
                <span class="text-xs md:text-sm text-background font-semibold"
                    >Areas We Service:</span
                >
                <div class="flex flex-wrap gap-2">
                    <a
                        href="/service-area/los-angeles"
                        class="text-xs font-bold text-background hover:text-accent transition-colors px-2 md:px-3 py-1 border border-background/30 hover:border-accent uppercase tracking-wider"
                    >
                        LOS ANGELES
                        <svg
                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a
                        href="/service-area/san-diego"
                        class="text-xs font-bold text-background hover:text-accent transition-colors px-2 md:px-3 py-1 border border-background/30 hover:border-accent uppercase tracking-wider"
                    >
                        SAN DIEGO
                        <svg
                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a
                        href="/service-area/san-francisco"
                        class="text-xs font-bold text-background hover:text-accent transition-colors px-2 md:px-3 py-1 border border-background/30 hover:border-accent uppercase tracking-wider"
                    >
                        SAN FRANCISCO
                        <svg
                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a
                        href="/service-area/sacramento"
                        class="text-xs font-bold text-background hover:text-accent transition-colors px-2 md:px-3 py-1 border border-background/30 hover:border-accent uppercase tracking-wider"
                    >
                        SACRAMENTO
                        <svg
                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="w-full bg-secondary border-t border-background/10">
        <div
            class="max-w-[1920px] mx-auto px-4 md:px-12 py-4 md:py-6 flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4"
        >
            <!-- Copyright -->
            <p class="text-xs md:text-sm text-background/80">
                2025 © ElectriTrade. All rights reserved
            </p>

            <!-- Legal Links -->
            <div class="flex items-center gap-4 md:gap-6">
                <a
                    href="/terms"
                    class="text-xs md:text-sm text-background/80 hover:text-background transition-colors"
                >
                    Terms & Conditions
                </a>
                <a
                    href="/privacy"
                    class="text-xs md:text-sm text-background/80 hover:text-background transition-colors"
                >
                    Privacy Policy
                </a>
            </div>

            <!-- Social Links -->
            <div class="flex items-center gap-3 md:gap-4">
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Instagram"
                >
                    <svg
                        class="w-4 md:w-5 h-4 md:h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Twitter"
                >
                    <svg
                        class="w-4 md:w-5 h-4 md:h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Facebook"
                >
                    <svg
                        class="w-4 md:w-5 h-4 md:h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>
