---
// ElectriTrade Footer Component
import Button from "../ui/Button.astro";
---

<footer class="w-full bg-primary text-background">
    <!-- Main Footer Content -->
    <div class="max-w-[1920px] mx-auto px-12 py-10">
        <!-- Top Section: Logo, Trust Badge, and Tagline -->
        <div class="flex flex-col items-center text-center mb-6">
            <img
                src="/logo.png"
                alt="ElectriTrade Logo"
                class="w-12 h-12 object-contain mb-2"
            />
            <div class="flex items-center gap-1 mb-1">
                <svg
                    class="w-4 h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path>
                </svg>
                <svg
                    class="w-4 h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path>
                </svg>
                <svg
                    class="w-4 h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path>
                </svg>
                <svg
                    class="w-4 h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path>
                </svg>
                <svg
                    class="w-4 h-4 text-accent"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path>
                </svg>
            </div>
            <h3 class="text-base font-heading font-bold mb-1">
                Trusted by 1000+ People Like You
            </h3>
            <p class="text-sm text-background/70">
                Contact us Today to Get Free Estimate
            </p>
        </div>

        <!-- Navigation Links -->
        <nav class="flex items-center justify-center gap-6 mb-6">
            <a
                href="/"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >HOME</a
            >
            <a
                href="/about"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >ABOUT US</a
            >
            <a
                href="/services"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >SERVICE AREA</a
            >
            <a
                href="/contact"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >CONTACT US</a
            >
            <a
                href="/specials"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >SPECIALS / COUPONS</a
            >
            <a
                href="/financing"
                class="text-background hover:text-accent transition-colors text-xs font-body"
                >FINANCING</a
            >
        </nav>

        <!-- CTA Buttons -->
        <div class="grid grid-cols-3 gap-4 max-w-4xl mx-auto mb-6">
            <a
                href="/quote"
                class="bg-accent hover:bg-accent/90 text-background px-5 py-3 flex items-center gap-3 transition-colors"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    ></path>
                </svg>
                <div>
                    <div class="text-xs font-body">SIMPLE & FREE</div>
                    <div class="text-sm font-bold">Request a Quote</div>
                </div>
            </a>
            <a
                href="tel:+1234567890"
                class="bg-accent hover:bg-accent/90 text-background px-5 py-3 flex items-center gap-3 transition-colors"
            >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path
                        d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                    ></path>
                </svg>
                <div>
                    <div class="text-xs font-body">CALL US</div>
                    <div class="text-sm font-bold">(123) 456-7890</div>
                </div>
            </a>
            <a
                href="mailto:info@electritrade.com"
                class="bg-accent hover:bg-accent/90 text-background px-5 py-3 flex items-center gap-3 transition-colors"
            >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path
                        d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
                    ></path>
                    <path
                        d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
                    ></path>
                </svg>
                <div>
                    <div class="text-xs font-body">EMAIL US</div>
                    <div class="text-sm font-bold">info@electritrade.com</div>
                </div>
            </a>
        </div>

        <!-- Service Areas -->
        <div class="border-t border-background/20 pt-5">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <svg
                        class="w-4 h-4 text-accent"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <span class="text-background text-sm font-bold"
                        >Address: Los Angeles, CA</span
                    >
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-background text-sm font-bold"
                        >Areas We Service:</span
                    >
                    <a
                        href="/service-area/los-angeles"
                        class="text-background hover:text-accent transition-colors px-3 py-1.5 border border-background/30 text-xs"
                        >LOS ANGELES →</a
                    >
                    <a
                        href="/service-area/san-diego"
                        class="text-background hover:text-accent transition-colors px-3 py-1.5 border border-background/30 text-xs"
                        >SAN DIEGO →</a
                    >
                    <a
                        href="/service-area/san-francisco"
                        class="text-background hover:text-accent transition-colors px-3 py-1.5 border border-background/30 text-xs"
                        >SAN FRANCISCO →</a
                    >
                    <a
                        href="/service-area/sacramento"
                        class="text-background hover:text-accent transition-colors px-3 py-1.5 border border-background/30 text-xs"
                        >SACRAMENTO →</a
                    >
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="w-full bg-secondary border-t border-background/10">
        <div
            class="max-w-[1920px] mx-auto px-12 py-3 flex items-center justify-between"
        >
            <p class="text-background/70 text-xs">
                2025 © ElectriTrade. All rights reserved
            </p>
            <div class="flex items-center gap-6">
                <a
                    href="/terms"
                    class="text-background/70 hover:text-background transition-colors text-xs"
                    >Terms & Conditions</a
                >
                <a
                    href="/privacy"
                    class="text-background/70 hover:text-background transition-colors text-xs"
                    >Privacy Policy</a
                >
            </div>
            <div class="flex items-center gap-3">
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Instagram"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Twitter"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="text-background hover:text-accent transition-colors"
                    aria-label="Facebook"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>
