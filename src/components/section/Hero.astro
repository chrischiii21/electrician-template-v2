---
import Button from "../ui/Button.astro";
import HeroOverlay from "./HeroOverlay.astro";
---

<section
    class="relative w-full h-screen min-h-[700px] bg-white overflow-hidden pt-[110px] lg:pt-[280px] mb-32"
>
    <!-- Full Size Background Image Carousel -->
    <div class="absolute inset-0 w-full h-full">
        <!-- Image 1 -->
        <div class="carousel-image absolute inset-0 w-full h-full opacity-100">
            <img
                src="/images/hero-1.avif"
                alt="Electrical work background"
                class="w-full h-full object-cover"
            />
        </div>
        <!-- Image 2 -->
        <div class="carousel-image absolute inset-0 w-full h-full opacity-0">
            <img
                src="/images/hero-2.avif"
                alt="Electrical panel work"
                class="w-full h-full object-cover"
            />
        </div>
        <!-- Image 3 -->
        <div class="carousel-image absolute inset-0 w-full h-full opacity-0">
            <img
                src="/images/hero-3.avif"
                alt="Commercial electrical services"
                class="w-full h-full object-cover"
            />
        </div>
        <!-- Image 4 -->
        <div class="carousel-image absolute inset-0 w-full h-full opacity-0">
            <img
                src="/images/hero-4.avif"
                alt="Residential electrical work"
                class="w-full h-full object-cover"
            />
        </div>
        <!-- Dark overlay for better text readability -->
        <div class="absolute inset-0 bg-black/40 z-10"></div>
    </div>

    <!-- Rotated Red Rectangle Background with Gradient -->
    <div
        class="absolute -left-32 -top-96 w-[1067px] h-[1650px] bg-gradient-to-br from-accent via-accent to-primary origin-center shadow-2xl z-10"
        style="transform: rotate(25deg);"
    >
    </div>

    <!-- Subtle Pattern Overlay -->
    <div
        class="absolute inset-0 opacity-5 z-20"
        style="background-image: radial-gradient(circle at 2px 2px, rgba(0,0,0,0.15) 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>

    <!-- Hero Content -->
    <div
        class="relative z-30 max-w-[1920px] mx-auto px-6 sm:px-12 lg:px-16 xl:px-20 h-full flex items-center"
    >
        <div class="w-full max-w-5xl">
            <!-- Main Heading -->
            <div class="mb-8 lg:mb-10 animate-fade-in-up">
                <h1
                    class="font-heading font-bold text-white leading-[1.05] tracking-tight"
                >
                    <div class="text-4xl sm:text-5xl drop-shadow-2xl">
                        Power Your
                    </div>
                    <div class="text-4xl sm:text-5xl drop-shadow-2xl">
                        Business Forward
                    </div>
                </h1>
                <p
                    class="mt-4 lg:mt-6 text-white/90 text-base sm:text-xl font-body max-w-xl lg:max-w-2xl leading-relaxed drop-shadow-lg"
                >
                    Expert electrical solutions for commercial and residential
                    properties. Licensed, insured, and ready to serve.
                </p>
            </div>

            <!-- CTA Buttons Group -->
            <div
                class="flex flex-col sm:flex-row gap-4 lg:gap-6 items-start animate-fade-in-up-delay"
            >
                <!-- Primary CTA with decorative element -->
                <div class="relative group">
                    <div
                        class="absolute -inset-1 bg-gradient-to-r from-accent to-primary blur opacity-25 group-hover:opacity-50 transition duration-300"
                    >
                    </div>
                    <div
                        class="relative bg-white shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
                    >
                        <Button
                            href="#contact"
                            variant="primary"
                            size="lg"
                            class=""
                        >
                            <span class="flex items-center gap-2 lg:gap-3">
                                Get Free Quote
                                <svg
                                    class="w-4 h-4 lg:w-5 lg:h-5 group-hover:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                            </span>
                        </Button>
                    </div>
                </div>

                <!-- Secondary CTA -->
                <div class="relative group">
                    <Button
                        href="tel:+1234567890"
                        variant="outline"
                        size="lg"
                        class="!border-white !text-white hover:!bg-white hover:!text-accent shadow-lg backdrop-blur-sm bg-white/10"
                    >
                        <span class="flex items-center gap-2 lg:gap-3">
                            <svg
                                class="w-4 h-4 lg:w-5 lg:h-5"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                                ></path>
                            </svg>
                            <span class="hidden sm:inline">Call Now:</span> (123)
                            456-7890
                        </span>
                    </Button>
                </div>
            </div>

            <!-- Trust Indicators -->
            <div
                class="mt-10 lg:mt-16 flex flex-wrap gap-6 lg:gap-8 items-center animate-fade-in-up-delay-2"
            >
                <div class="flex items-center gap-3 text-white/90">
                    <div
                        class="w-10 h-10 lg:w-12 lg:h-12 bg-white/20 backdrop-blur-sm flex items-center justify-center shrink-0"
                    >
                        <svg
                            class="w-5 h-5 lg:w-6 lg:h-6 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <div>
                        <div class="font-bold text-base">
                            Licensed & Insured
                        </div>
                        <div class="text-sm text-white/70">Fully Certified</div>
                    </div>
                </div>

                <div class="flex items-center gap-3 text-white/90">
                    <div
                        class="w-10 h-10 lg:w-12 lg:h-12 bg-white/20 backdrop-blur-sm flex items-center justify-center shrink-0"
                    >
                        <svg
                            class="w-5 h-5 lg:w-6 lg:h-6 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <div class="font-bold text-base">24/7 Emergency</div>
                        <div class="text-sm text-white/70">
                            Always Available
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-3 text-white/90">
                    <div
                        class="w-10 h-10 lg:w-12 lg:h-12 bg-white/20 backdrop-blur-sm flex items-center justify-center shrink-0"
                    >
                        <svg
                            class="w-5 h-5 lg:w-6 lg:h-6 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <div class="font-bold text-base">5-Star Rated</div>
                        <div class="text-sm text-white/70">500+ Reviews</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce hidden lg:block"
    >
        <div
            class="w-6 h-10 border-2 border-white/50 flex items-start justify-center p-2"
        >
            <div class="w-1 h-2 bg-white/50"></div>
        </div>
    </div>
</section>

<!-- Hero Overlay Section -->
<HeroOverlay />

<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    .animate-fade-in-up-delay {
        opacity: 0;
        animation: fade-in-up 0.8s ease-out 0.2s forwards;
    }

    .animate-fade-in-up-delay-2 {
        opacity: 0;
        animation: fade-in-up 0.8s ease-out 0.4s forwards;
    }

    .carousel-image {
        transition: opacity 2s ease-in-out;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const images =
            document.querySelectorAll<HTMLElement>(".carousel-image");
        let currentIndex = 0;

        function showNextImage() {
            // Fade out current image
            if (images[currentIndex]) {
                images[currentIndex].style.opacity = "0";
            }

            // Move to next image
            currentIndex = (currentIndex + 1) % images.length;

            // Fade in next image
            if (images[currentIndex]) {
                images[currentIndex].style.opacity = "1";
            }
        }

        // Change image every 5 seconds
        setInterval(showNextImage, 5000);
    });
</script>
